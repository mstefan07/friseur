# Public site URL for metadata, sitemap, robots, and JSON-LD.
# Set the final production domain in Vercel after purchase.
NEXT_PUBLIC_SITE_URL=https://www.yunes-barber-langen.de

# Google Calendar appointment scheduling (public embed URL).
# Optional override for the iframe on the booking section.
NEXT_PUBLIC_GOOGLE_CALENDAR_SCHEDULING_URL=

# Legacy API placeholders (not used when Google scheduling iframe is active).
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
